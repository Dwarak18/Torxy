Cause 2 — Tor DataDirectory permission issue
Fix in docker/tor/entrypoint.sh:
bash#!/bin/sh
set -e

if [ -z "${TOR_CONTROL_PASSWORD}" ]; then
    echo "[Torxy] ERROR: TOR_CONTROL_PASSWORD is not set"
