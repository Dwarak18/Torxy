set -e

if [ -z "${TOR_CONTROL_PASSWORD}" ]; then
    echo "[Torxy] ERROR: TOR_CONTROL_PASSWORD is not set"
    exit 1
fi

HASHED=$(tor --hash-password "${TOR_CONTROL_PASSWORD}" 2>/dev/null | grep "^16:")

